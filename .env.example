# Tencent QQ Open Platform credentials: https://q.qq.com/
QQ_BRIDGE_BOT_APP_ID=your_app_id_here
QQ_BRIDGE_BOT_APP_SECRET=your_app_secret_here

QQ_BRIDGE_DB_PATH=data/bridge.db
QQ_BRIDGE_LOG_LEVEL=INFO
QQ_BRIDGE_LOG_PATH=logs/qq_bridge.log

# Optional comma-separated allowlists. Empty means allow all reachable senders.
# Send /id to the bot to get these OpenID values.
QQ_BRIDGE_ALLOWED_USERS=
QQ_BRIDGE_ALLOWED_GROUPS=

# QQ text messages have size limits. Long Claude replies are split.
QQ_BRIDGE_MESSAGE_CHUNK_SIZE=1800

# Claude replies are sent as QQ Markdown by default.
# If Tencent rejects Markdown for this bot, the bridge falls back to plain text.
QQ_BRIDGE_MARKDOWN_ENABLED=true
QQ_BRIDGE_MARKDOWN_FALLBACK_TO_TEXT=true
